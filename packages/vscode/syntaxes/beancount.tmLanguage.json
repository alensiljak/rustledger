{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Beancount",
  "scopeName": "source.beancount",
  "patterns": [
    { "include": "#comment" },
    { "include": "#option" },
    { "include": "#include" },
    { "include": "#plugin" },
    { "include": "#pushtag" },
    { "include": "#poptag" },
    { "include": "#pushmeta" },
    { "include": "#popmeta" },
    { "include": "#transaction" },
    { "include": "#balance" },
    { "include": "#open" },
    { "include": "#close" },
    { "include": "#pad" },
    { "include": "#price-directive" },
    { "include": "#event" },
    { "include": "#note" },
    { "include": "#document" },
    { "include": "#commodity-directive" },
    { "include": "#query-directive" },
    { "include": "#custom" },
    { "include": "#posting" },
    { "include": "#metadata" }
  ],
  "repository": {
    "comment": {
      "match": ";.*$",
      "name": "comment.line.semicolon.beancount"
    },

    "date": {
      "match": "\\d{4}[-/]\\d{2}[-/]\\d{2}",
      "name": "constant.numeric.date.beancount"
    },

    "string": {
      "match": "\"[^\"]*\"",
      "name": "string.quoted.double.beancount"
    },

    "number": {
      "match": "[-+]?[\\d,]+(\\.[\\d,]*)?",
      "name": "constant.numeric.beancount"
    },

    "currency": {
      "match": "\\b[A-Z][A-Z0-9'._{-}]{0,23}\\b",
      "name": "support.type.currency.beancount"
    },

    "account": {
      "match": "\\b(Assets|Liabilities|Equity|Income|Expenses)(:[A-Z][A-Za-z0-9-]*)+\\b",
      "name": "variable.other.account.beancount"
    },

    "tag": {
      "match": "#[A-Za-z0-9_-]+",
      "name": "entity.name.tag.beancount"
    },

    "link": {
      "match": "\\^[A-Za-z0-9_-]+",
      "name": "entity.name.link.beancount"
    },

    "flag": {
      "match": "(?<=\\d\\s)[*!](?=\\s)",
      "name": "keyword.operator.flag.beancount"
    },

    "metadata": {
      "match": "^\\s+([a-z][a-z0-9_-]*)\\s*(:)",
      "captures": {
        "1": { "name": "entity.other.attribute-name.metadata.beancount" },
        "2": { "name": "punctuation.separator.metadata.beancount" }
      }
    },

    "option": {
      "begin": "^(option)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "keyword.control.option.beancount" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#comment" }
      ]
    },

    "include": {
      "begin": "^(include)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "keyword.control.include.beancount" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#comment" }
      ]
    },

    "plugin": {
      "begin": "^(plugin)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "keyword.control.plugin.beancount" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#comment" }
      ]
    },

    "pushtag": {
      "match": "^(pushtag)\\s+(#[A-Za-z0-9_-]+)",
      "captures": {
        "1": { "name": "keyword.control.pushtag.beancount" },
        "2": { "name": "entity.name.tag.beancount" }
      }
    },

    "poptag": {
      "match": "^(poptag)\\s+(#[A-Za-z0-9_-]+)",
      "captures": {
        "1": { "name": "keyword.control.poptag.beancount" },
        "2": { "name": "entity.name.tag.beancount" }
      }
    },

    "pushmeta": {
      "begin": "^(pushmeta)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "keyword.control.pushmeta.beancount" }
      },
      "patterns": [
        { "include": "#metadata" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#account" },
        { "include": "#date" },
        { "include": "#comment" }
      ]
    },

    "popmeta": {
      "begin": "^(popmeta)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "keyword.control.popmeta.beancount" }
      },
      "patterns": [
        { "include": "#metadata" },
        { "include": "#comment" }
      ]
    },

    "transaction": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+([*!]|txn)\\s*",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.operator.flag.beancount" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#tag" },
        { "include": "#link" },
        { "include": "#comment" }
      ]
    },

    "balance": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(balance)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.balance.beancount" }
      },
      "patterns": [
        { "include": "#account" },
        { "include": "#number" },
        { "include": "#currency" },
        { "include": "#comment" }
      ]
    },

    "open": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(open)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.open.beancount" }
      },
      "patterns": [
        { "include": "#account" },
        { "include": "#currency" },
        { "include": "#string" },
        { "include": "#comment" }
      ]
    },

    "close": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(close)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.close.beancount" }
      },
      "patterns": [
        { "include": "#account" },
        { "include": "#comment" }
      ]
    },

    "pad": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(pad)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.pad.beancount" }
      },
      "patterns": [
        { "include": "#account" },
        { "include": "#comment" }
      ]
    },

    "price-directive": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(price)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.price.beancount" }
      },
      "patterns": [
        { "include": "#number" },
        { "include": "#currency" },
        { "include": "#comment" }
      ]
    },

    "event": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(event)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.event.beancount" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#comment" }
      ]
    },

    "note": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(note)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.note.beancount" }
      },
      "patterns": [
        { "include": "#account" },
        { "include": "#string" },
        { "include": "#comment" }
      ]
    },

    "document": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(document)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.document.beancount" }
      },
      "patterns": [
        { "include": "#account" },
        { "include": "#string" },
        { "include": "#tag" },
        { "include": "#link" },
        { "include": "#comment" }
      ]
    },

    "commodity-directive": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(commodity)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.commodity.beancount" }
      },
      "patterns": [
        { "include": "#currency" },
        { "include": "#comment" }
      ]
    },

    "query-directive": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(query)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.query.beancount" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#comment" }
      ]
    },

    "custom": {
      "begin": "^(\\d{4}[-/]\\d{2}[-/]\\d{2})\\s+(custom)\\s+",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "constant.numeric.date.beancount" },
        "2": { "name": "keyword.other.directive.custom.beancount" }
      },
      "patterns": [
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#account" },
        { "include": "#currency" },
        { "include": "#date" },
        { "include": "#comment" }
      ]
    },

    "posting": {
      "begin": "^(\\s+)([*!]\\s+)?([A-Z][A-Za-z0-9-]*(:[A-Z][A-Za-z0-9-]*)+)",
      "end": "$",
      "beginCaptures": {
        "2": { "name": "keyword.operator.flag.beancount" },
        "3": { "name": "variable.other.account.beancount" }
      },
      "patterns": [
        {
          "begin": "\\{",
          "end": "\\}",
          "name": "meta.cost.beancount",
          "patterns": [
            { "include": "#number" },
            { "include": "#currency" },
            { "include": "#date" },
            { "include": "#string" }
          ]
        },
        {
          "match": "@@?",
          "name": "keyword.operator.price.beancount"
        },
        { "include": "#number" },
        { "include": "#currency" },
        { "include": "#comment" }
      ]
    }
  }
}
