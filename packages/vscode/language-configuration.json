{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\d{4}-\\d{2}-\\d{2}\\s+(\\*|!|txn|open|close|balance|pad|event|note|document|commodity|query|custom|price)",
    "decreaseIndentPattern": "^$"
  },
  "wordPattern": "[A-Za-z][A-Za-z0-9:._-]*"
}
