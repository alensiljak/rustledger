{
  "openrpc": "1.3.0",
  "info": {
    "title": "Rustledger FFI API",
    "description": "JSON-RPC 2.0 API for interacting with Rustledger - a fast Beancount-compatible ledger engine.",
    "version": "1.0.0",
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "name": "WASI Module",
      "summary": "Rustledger FFI-WASI module (via stdin/stdout)",
      "description": "Run via wasmtime: echo '{...}' | wasmtime rustledger-ffi-wasi.wasm"
    }
  ],
  "methods": [
    {
      "name": "ledger.load",
      "summary": "Parse and load beancount source",
      "description": "Parses beancount source code and returns structured data including entries, errors, options, and plugins.",
      "params": [
        {
          "name": "source",
          "description": "Beancount source code to parse",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "filename",
          "description": "Optional filename for error messages",
          "required": false,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "LoadOutput",
        "description": "Parsed ledger data",
        "schema": {
          "$ref": "#/components/schemas/LoadOutput"
        }
      },
      "examples": [
        {
          "name": "Basic transaction",
          "params": [
            {
              "name": "source",
              "value": "2024-01-01 open Assets:Bank USD\n2024-01-02 * \"Coffee\"\n  Expenses:Food 5 USD\n  Assets:Bank"
            }
          ],
          "result": {
            "name": "Result",
            "value": {
              "api_version": "1.0",
              "entries": [],
              "errors": [],
              "options": {},
              "plugins": [],
              "includes": []
            }
          }
        }
      ]
    },
    {
      "name": "ledger.loadFile",
      "summary": "Load a beancount file from disk",
      "description": "Loads a beancount file with full processing: includes, booking, interpolation, and optional plugins.",
      "params": [
        {
          "name": "path",
          "description": "Path to beancount file",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "plugins",
          "description": "Optional list of plugin names to apply",
          "required": false,
          "schema": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      ],
      "result": {
        "name": "LoadFullOutput",
        "description": "Fully processed ledger data",
        "schema": {
          "$ref": "#/components/schemas/LoadFullOutput"
        }
      }
    },
    {
      "name": "ledger.validate",
      "summary": "Validate beancount source",
      "description": "Validates beancount source code and returns any errors found.",
      "params": [
        {
          "name": "source",
          "description": "Beancount source code to validate",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "ValidateOutput",
        "description": "Validation result",
        "schema": {
          "$ref": "#/components/schemas/ValidateOutput"
        }
      }
    },
    {
      "name": "ledger.validateFile",
      "summary": "Validate a beancount file",
      "description": "Validates a beancount file from disk and returns any errors found.",
      "params": [
        {
          "name": "path",
          "description": "Path to beancount file",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "ValidateOutput",
        "description": "Validation result",
        "schema": {
          "$ref": "#/components/schemas/ValidateOutput"
        }
      }
    },
    {
      "name": "query.execute",
      "summary": "Execute a BQL query",
      "description": "Executes a Beancount Query Language (BQL) query on the provided source.",
      "params": [
        {
          "name": "source",
          "description": "Beancount source code",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "query",
          "description": "BQL query string",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "QueryOutput",
        "description": "Query result with columns and rows",
        "schema": {
          "$ref": "#/components/schemas/QueryOutput"
        }
      }
    },
    {
      "name": "query.executeFile",
      "summary": "Execute a BQL query on a file",
      "description": "Executes a BQL query on a beancount file from disk.",
      "params": [
        {
          "name": "path",
          "description": "Path to beancount file",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "query",
          "description": "BQL query string",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "QueryOutput",
        "description": "Query result with columns and rows",
        "schema": {
          "$ref": "#/components/schemas/QueryOutput"
        }
      }
    },
    {
      "name": "query.batch",
      "summary": "Execute multiple BQL queries",
      "description": "Executes multiple BQL queries on the same source, returning both load output and query results.",
      "params": [
        {
          "name": "source",
          "description": "Beancount source code",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "queries",
          "description": "List of BQL query strings",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        {
          "name": "filename",
          "description": "Optional filename for error messages",
          "required": false,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "BatchOutput",
        "description": "Load output and array of query results",
        "schema": {
          "$ref": "#/components/schemas/BatchOutput"
        }
      }
    },
    {
      "name": "query.batchFile",
      "summary": "Execute multiple BQL queries on a file",
      "description": "Executes multiple BQL queries on a beancount file from disk.",
      "params": [
        {
          "name": "path",
          "description": "Path to beancount file",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "queries",
          "description": "List of BQL query strings",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      ],
      "result": {
        "name": "BatchOutput",
        "description": "Load output and array of query results",
        "schema": {
          "$ref": "#/components/schemas/BatchOutput"
        }
      }
    },
    {
      "name": "format.source",
      "summary": "Format beancount source",
      "description": "Formats beancount source code according to standard conventions.",
      "params": [
        {
          "name": "source",
          "description": "Beancount source code to format",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "FormatResult",
        "description": "Formatted source code",
        "schema": {
          "$ref": "#/components/schemas/FormatResult"
        }
      }
    },
    {
      "name": "format.file",
      "summary": "Format a beancount file",
      "description": "Formats a beancount file from disk.",
      "params": [
        {
          "name": "path",
          "description": "Path to beancount file",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "FormatResult",
        "description": "Formatted source code",
        "schema": {
          "$ref": "#/components/schemas/FormatResult"
        }
      }
    },
    {
      "name": "format.entry",
      "summary": "Format a single entry",
      "description": "Formats a single beancount entry from JSON representation.",
      "params": [
        {
          "name": "entry",
          "description": "Entry to format",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/InputEntry"
          }
        }
      ],
      "result": {
        "name": "FormatResult",
        "description": "Formatted entry",
        "schema": {
          "$ref": "#/components/schemas/FormatResult"
        }
      }
    },
    {
      "name": "format.entries",
      "summary": "Format multiple entries",
      "description": "Formats multiple beancount entries from JSON representation.",
      "params": [
        {
          "name": "entries",
          "description": "Entries to format",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InputEntry"
            }
          }
        }
      ],
      "result": {
        "name": "FormatResult",
        "description": "Formatted entries",
        "schema": {
          "$ref": "#/components/schemas/FormatResult"
        }
      }
    },
    {
      "name": "entry.create",
      "summary": "Create an entry from JSON",
      "description": "Creates a beancount entry from JSON input and returns it in the standard output format.",
      "params": [
        {
          "name": "entry",
          "description": "Entry to create",
          "required": true,
          "schema": {
            "$ref": "#/components/schemas/InputEntry"
          }
        }
      ],
      "result": {
        "name": "CreateEntryResult",
        "description": "Created entry",
        "schema": {
          "$ref": "#/components/schemas/CreateEntryResult"
        }
      }
    },
    {
      "name": "entry.createBatch",
      "summary": "Create multiple entries from JSON",
      "description": "Creates multiple beancount entries from JSON input.",
      "params": [
        {
          "name": "entries",
          "description": "Entries to create",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InputEntry"
            }
          }
        }
      ],
      "result": {
        "name": "CreateEntriesResult",
        "description": "Created entries",
        "schema": {
          "$ref": "#/components/schemas/CreateEntriesResult"
        }
      }
    },
    {
      "name": "entry.filter",
      "summary": "Filter entries by date range",
      "description": "Filters entries to include only those within the specified date range [beginDate, endDate).",
      "params": [
        {
          "name": "entries",
          "description": "Entries to filter",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DirectiveJson"
            }
          }
        },
        {
          "name": "beginDate",
          "description": "Begin date (inclusive, YYYY-MM-DD format)",
          "required": true,
          "schema": {
            "type": "string",
            "format": "date"
          }
        },
        {
          "name": "endDate",
          "description": "End date (exclusive, YYYY-MM-DD format)",
          "required": true,
          "schema": {
            "type": "string",
            "format": "date"
          }
        }
      ],
      "result": {
        "name": "FilterResult",
        "description": "Filtered entries",
        "schema": {
          "type": "object",
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/DirectiveJson"
              }
            }
          }
        }
      }
    },
    {
      "name": "entry.clamp",
      "summary": "Clamp entries to date range",
      "description": "Clamps entries to the specified date range with opening balance summarization.",
      "params": [
        {
          "name": "entries",
          "description": "Entries to clamp",
          "required": true,
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DirectiveJson"
            }
          }
        },
        {
          "name": "beginDate",
          "description": "Begin date (inclusive, YYYY-MM-DD format)",
          "required": true,
          "schema": {
            "type": "string",
            "format": "date"
          }
        },
        {
          "name": "endDate",
          "description": "End date (exclusive, YYYY-MM-DD format)",
          "required": true,
          "schema": {
            "type": "string",
            "format": "date"
          }
        }
      ],
      "result": {
        "name": "ClampResult",
        "description": "Clamped entries",
        "schema": {
          "type": "object",
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/DirectiveJson"
              }
            }
          }
        }
      }
    },
    {
      "name": "util.version",
      "summary": "Get API version information",
      "description": "Returns the API version and package version.",
      "params": [],
      "result": {
        "name": "VersionResult",
        "description": "Version information",
        "schema": {
          "$ref": "#/components/schemas/VersionResult"
        }
      }
    },
    {
      "name": "util.types",
      "summary": "Get type information",
      "description": "Returns information about supported directive types, booking methods, and account types.",
      "params": [],
      "result": {
        "name": "TypesOutput",
        "description": "Type information",
        "schema": {
          "$ref": "#/components/schemas/TypesOutput"
        }
      }
    },
    {
      "name": "util.schema",
      "summary": "Get JSON Schema",
      "description": "Returns the JSON Schema for the API types.",
      "params": [],
      "result": {
        "name": "JsonSchema",
        "description": "JSON Schema document",
        "schema": {
          "type": "object"
        }
      }
    },
    {
      "name": "util.isEncrypted",
      "summary": "Check if file is encrypted",
      "description": "Checks if the given path appears to be an encrypted file (based on extension).",
      "params": [
        {
          "name": "path",
          "description": "Path to check",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "IsEncryptedResult",
        "description": "Encryption check result",
        "schema": {
          "$ref": "#/components/schemas/IsEncryptedResult"
        }
      }
    },
    {
      "name": "util.getAccountType",
      "summary": "Get account type from name",
      "description": "Extracts the account type (Assets, Liabilities, Equity, Income, Expenses) from an account name.",
      "params": [
        {
          "name": "account",
          "description": "Account name",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "GetAccountTypeResult",
        "description": "Account type",
        "schema": {
          "$ref": "#/components/schemas/GetAccountTypeResult"
        }
      }
    }
  ],
  "components": {
    "schemas": {
      "LoadOutput": {
        "type": "object",
        "description": "Result of parsing beancount source",
        "properties": {
          "api_version": {
            "type": "string",
            "description": "API version"
          },
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DirectiveJson"
            },
            "description": "Parsed directives"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            },
            "description": "Parse errors"
          },
          "options": {
            "$ref": "#/components/schemas/LedgerOptions",
            "description": "Ledger options"
          },
          "plugins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Plugin"
            },
            "description": "Declared plugins"
          },
          "includes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Include paths"
          }
        },
        "required": ["api_version", "entries", "errors"]
      },
      "LoadFullOutput": {
        "type": "object",
        "description": "Result of fully loading a beancount file",
        "properties": {
          "api_version": {
            "type": "string"
          },
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DirectiveJson"
            }
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            }
          },
          "options": {
            "$ref": "#/components/schemas/LedgerOptions"
          },
          "plugins": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Plugin"
            }
          },
          "loaded_files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of all loaded files (main + includes)"
          }
        },
        "required": ["api_version", "entries", "errors", "loaded_files"]
      },
      "ValidateOutput": {
        "type": "object",
        "description": "Result of validating beancount source",
        "properties": {
          "api_version": {
            "type": "string"
          },
          "valid": {
            "type": "boolean",
            "description": "Whether the source is valid"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "required": ["api_version", "valid", "errors"]
      },
      "QueryOutput": {
        "type": "object",
        "description": "Result of executing a BQL query",
        "properties": {
          "api_version": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ColumnInfo"
            },
            "description": "Column metadata (name and datatype)"
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {}
            },
            "description": "Query result rows"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "required": ["api_version", "columns", "rows", "errors"]
      },
      "BatchOutput": {
        "type": "object",
        "description": "Result of executing multiple queries",
        "properties": {
          "api_version": {
            "type": "string"
          },
          "load": {
            "$ref": "#/components/schemas/LoadOutput",
            "description": "Load output for the source"
          },
          "queries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QueryOutput"
            },
            "description": "Results for each query"
          }
        },
        "required": ["api_version", "load", "queries"]
      },
      "FormatResult": {
        "type": "object",
        "description": "Result of formatting",
        "properties": {
          "formatted": {
            "type": "string",
            "description": "Formatted beancount source"
          }
        },
        "required": ["formatted"]
      },
      "CreateEntryResult": {
        "type": "object",
        "description": "Result of creating an entry",
        "properties": {
          "entry": {
            "$ref": "#/components/schemas/DirectiveJson"
          }
        },
        "required": ["entry"]
      },
      "CreateEntriesResult": {
        "type": "object",
        "description": "Result of creating multiple entries",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DirectiveJson"
            }
          }
        },
        "required": ["entries"]
      },
      "VersionResult": {
        "type": "object",
        "description": "Version information",
        "properties": {
          "apiVersion": {
            "type": "string",
            "description": "API version"
          },
          "version": {
            "type": "string",
            "description": "Package version"
          }
        },
        "required": ["apiVersion", "version"]
      },
      "TypesOutput": {
        "type": "object",
        "description": "Type information",
        "properties": {
          "api_version": {
            "type": "string"
          },
          "all_directives": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "All supported directive types"
          },
          "booking_methods": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Supported booking methods"
          },
          "account_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Account type prefixes"
          },
          "missing": {
            "$ref": "#/components/schemas/MissingSentinel",
            "description": "Sentinel describing missing/interpolated amounts"
          }
        },
        "required": ["api_version", "all_directives", "booking_methods", "account_types", "missing"]
      },
      "MissingSentinel": {
        "type": "object",
        "description": "Describes how missing/interpolated amounts are represented",
        "properties": {
          "description": {
            "type": "string"
          },
          "json_representation": {
            "type": "string"
          }
        },
        "required": ["description", "json_representation"]
      },
      "ColumnInfo": {
        "type": "object",
        "description": "Query column metadata",
        "properties": {
          "name": {
            "type": "string",
            "description": "Column name"
          },
          "datatype": {
            "type": "string",
            "description": "Column data type"
          }
        },
        "required": ["name", "datatype"]
      },
      "IsEncryptedResult": {
        "type": "object",
        "properties": {
          "encrypted": {
            "type": "boolean"
          }
        },
        "required": ["encrypted"]
      },
      "GetAccountTypeResult": {
        "type": "object",
        "properties": {
          "account_type": {
            "type": "string",
            "enum": ["assets", "liabilities", "equity", "income", "expenses", "unknown"]
          }
        },
        "required": ["account_type"]
      },
      "DirectiveJson": {
        "type": "object",
        "description": "A beancount directive in JSON format",
        "properties": {
          "type": {
            "type": "string",
            "description": "Directive type"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Directive date"
          },
          "line": {
            "type": "integer",
            "description": "Source line number"
          },
          "filename": {
            "type": "string",
            "description": "Source filename"
          },
          "meta": {
            "type": "object",
            "description": "Metadata"
          }
        },
        "required": ["type", "date"]
      },
      "InputEntry": {
        "type": "object",
        "description": "Input entry for creating directives",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["transaction", "open", "close", "balance", "pad", "commodity", "price", "event", "note", "document", "query", "custom"],
            "description": "Entry type"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Entry date (YYYY-MM-DD)"
          }
        },
        "required": ["type", "date"]
      },
      "Error": {
        "type": "object",
        "description": "An error message",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "line": {
            "type": "integer",
            "description": "Line number"
          },
          "column": {
            "type": "integer",
            "description": "Column number"
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning"],
            "description": "Error severity"
          }
        },
        "required": ["message"]
      },
      "LedgerOptions": {
        "type": "object",
        "description": "Ledger options",
        "properties": {
          "title": {
            "type": "string"
          },
          "operating_currency": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "booking_method": {
            "type": "string"
          }
        }
      },
      "Plugin": {
