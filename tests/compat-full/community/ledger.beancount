; Options
option "name_assets" "Majetek"
option "name_liabilities" "Zavazky"
option "name_equity" "Ciste-jmeni"
option "name_income" "Prijmy"
option "name_expenses" "Vydaje"
option "operating_currency" "CZK"

; Ucty
2025-01-01 open Majetek:Banky:Easy-Bank:BU     CZK
2025-01-01 open Majetek:Banky:Easy-Bank:BU-EUR EUR
2025-01-01 open Majetek:Hotovost:Penezenka     CZK
2025-01-01 open Ciste-jmeni:Pocatecni-stav     CZK, EUR
