; Issue: https://github.com/rustledger/rustledger/issues/279
; Description: Crypto FIFO with multi-lot sales and in-kind fees fails
; Expected: No errors - multi-posting transactions should track inventory state

option "operating_currency" "USD"

2020-01-01 open Assets:Crypto:Kraken  ADA,USD  "FIFO"
2020-01-01 open Equity:Opening-Balances
2020-01-01 open Income:Crypto:Trading

; Lot 1: Legacy holdings (oldest - sold first via FIFO)
2021-01-01 * "Opening balance from cold wallet"
  Assets:Crypto:Kraken   350000 ADA {0.50 USD, 2021-01-01}
  Equity:Opening-Balances

; Lot 2: Recent transfer
2022-05-19 * "Opening balance from another exchange"
  Assets:Crypto:Kraken   605489.04 ADA {0.5169 USD, 2022-05-19}
  Equity:Opening-Balances

; Lot 3: Purchases
2022-05-20 * "Buy ADA"
  Assets:Crypto:Kraken   100000 ADA {0.517 USD, 2022-05-20}
  Assets:Crypto:Kraken   -51700 USD

; Sale + fee (multi-posting)
; Cost basis: 19090.32 ADA * $0.50 = $9545.16
2022-05-22 * "Kraken" "Trade - SALE" #kraken
  Assets:Crypto:Kraken    -19000 ADA {}
  Assets:Crypto:Kraken       -90.32 ADA {}
  Assets:Crypto:Kraken   9545.16 USD
  Income:Crypto:Trading

; Another sale exhausting lot 1
; Remaining: 350000 - 19090.32 = 330909.68 ADA at $0.50
; Cost: 330909.68 * $0.50 = $165454.84
2022-05-23 * "Kraken" "Trade - SALE 2" #kraken
  Assets:Crypto:Kraken     -330909.68 ADA {}
  Assets:Crypto:Kraken    165454.84 USD
  Income:Crypto:Trading

; Final balance: Lot 2 + Lot 3 = 605489.04 + 100000 = 705489.04
2022-05-24 balance Assets:Crypto:Kraken  705489.04 ADA
