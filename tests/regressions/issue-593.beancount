; Issue: https://github.com/rustledger/rustledger/issues/593
; Description: BQL cost() and value() functions returning incorrect values
;
; Bug 1 (cost): cost() was using .abs() on unit numbers, causing sell transactions
; to contribute positive costs instead of negative costs. This led to incorrect
; sums when mixing buys and sells.
;
; Bug 2 (value): value() wasn't finding the latest implicit price from @ annotations
;
; Expected behavior:
;   cost():
;     - Buy 5 ABC @ 1.25 EUR = +6.25 EUR
;     - Sell 5 ABC @ 1.25 EUR = -6.25 EUR (negative because units are negative)
;     - SUM(cost(position)) should equal net cost (4 ABC * 1.30 = 5.20 EUR)
;
;   value():
;     - Should use latest price (1.40 EUR from last @ annotation)
;     - SUM(value(position)) should equal 4 ABC * 1.40 = 5.60 EUR

; ASSERT: no_errors
; ASSERT: query "SELECT SUM(cost(position)) WHERE account = 'Equity:Stocks'" contains "5.20 EUR"

plugin "beancount.plugins.implicit_prices"

1900-01-01 open Equity:Stocks
1900-01-01 open Assets:Bank:Checking EUR

2025-04-01 txn "Buy Stocks"
  Equity:Stocks 5 ABC { 1.25 EUR }
  Assets:Bank:Checking

2025-04-02 txn "Buy more stocks"
  Equity:Stocks 7 ABC { 1.30 EUR }
  Assets:Bank:Checking

2025-04-15 price ABC  1.35 EUR

2025-09-09 txn "Sell complete lot"
  Equity:Stocks -5 ABC { 1.25 EUR, 2025-04-01 } @ 1.35 EUR
  Assets:Bank:Checking

2025-09-10 txn "Sell some stock" "split lot"
  Equity:Stocks -3 ABC { 1.30 EUR, 2025-04-02 } @ 1.40 EUR
  Assets:Bank:Checking
